# ===========================================
# JARDINIA FRANCE - Variables d'environnement
# ===========================================
# Copiez ce fichier en .env.local et remplissez les valeurs

# -------------------------------------
# Base de données PostgreSQL
# -------------------------------------
DATABASE_URL="postgresql://jardinia:jardinia_password@localhost:5432/jardinia_db"

# -------------------------------------
# NextAuth / Auth.js
# -------------------------------------
NEXTAUTH_SECRET="votre_secret_nextauth_tres_long_et_aleatoire_minimum_32_caracteres"
NEXTAUTH_URL="http://localhost:3000"

# Auth providers OAuth (optionnels)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# -------------------------------------
# Stripe (Paiements)
# -------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# -------------------------------------
# Email (Nodemailer)
# -------------------------------------
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@jardinia-france.com"
SMTP_PASS="votre_mot_de_passe_smtp"
SMTP_FROM="Jardinia France <noreply@jardinia-france.com>"

# -------------------------------------
# Application
# -------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Jardinia France"

# -------------------------------------
# Admin (email de l'administrateur)
# -------------------------------------
ADMIN_EMAIL="admin@jardinia-france.com"
